# FSAE Sim webapp environment variables.
# Copy to `.env.local` (gitignored) and adjust as needed.

# Base URL for the FastAPI backend. In dev the default "/api" is served
# through the Vite proxy (see vite.config.ts). For standalone builds or
# when the backend is on a different host/port, set this explicitly.
# The FastAPI dev server runs on port 8001 (see backend/main.py).
VITE_API_BASE=http://localhost:8001/api
